# Database
DATABASE_URL=postgresql+asyncpg://splitease:password@localhost:5432/splitease

# Redis
REDIS_URL=redis://localhost:6379

# JWT - generate with: openssl rand -hex 32
SECRET_KEY=your-256-bit-secret-key-here

# Service URLs (used by gateway)
AUTH_SERVICE_URL=http://auth-service:8001
EXPENSE_SERVICE_URL=http://expense-service:8002

# Email (optional - use Gmail App Password or SES SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com

# App
APP_URL=http://localhost:3000
ENVIRONMENT=development

# Web Push VAPID keys - generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@yourdomain.com

# AWS (for deployment only)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_REGISTRY=
